<UserControl x:Class="Altaxo.Gui.Science.Spectroscopy.SpikeRemoval.SpikeRemovalByEnsembleStatisticsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Altaxo.Gui.Science.Spectroscopy"
             xmlns:localModel="clr-namespace:Altaxo.Gui.Science.Spectroscopy.SpikeRemoval;assembly=AltaxoBase"
             xmlns:axogc="clr-namespace:Altaxo.Gui.Common"
             d:DataContext="{d:DesignInstance Type=localModel:SpikeRemovalByEnsembleStatisticsController}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="4"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0"
               Content="Maximum width (points):"/>
        <axogc:DoubleUpDown Grid.Row="0" Grid.Column="2"
                           Value="{Binding MaximalWidth}"
                            Minimum="0"
                            />

        <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                  IsChecked="{Binding EliminateNegativeSpikes}"
                  Content="Eliminate negative spikes, too"/>

        <Label Grid.Row="4"
               Grid.Column="0"
               Content="Number of sigmas for filtering:" />
        <axogc:DoubleUpDown Grid.Row="4"
                            Grid.Column="2"
                            Value="{Binding  NumberOfSigmas}"
                            Minimum="0" />

        <Label Grid.Row="6"
               Grid.Column="0"
               Content="Minimal signal-to-noise of peaks:" />
        
        <axogc:QuantityWithUnitTextBox Grid.Row="6"
                            Grid.Column="2"
                            SelectedQuantity="{Binding MinimalSignalToNoiseRatio}"
                                       UnitEnvironment="{Binding UnitEnvironmentRelation}" />
    </Grid>
</UserControl>
