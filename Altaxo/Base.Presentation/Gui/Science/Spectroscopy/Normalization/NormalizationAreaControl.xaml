<UserControl x:Class="Altaxo.Gui.Science.Spectroscopy.Normalization.NormalizationAreaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Altaxo.Gui.Science.Spectroscopy"
             xmlns:localModel="clr-namespace:Altaxo.Gui.Science.Spectroscopy.Normalization;assembly=AltaxoBase"
             xmlns:axogc="clr-namespace:Altaxo.Gui.Common"
             xmlns:axogcc="clr-namespace:Altaxo.Gui.Common.Converters"
             d:DataContext="{d:DesignInstance Type=localModel:NormalizationAreaController}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="4"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0"
               Content="Minimal x-value:"/>
        <axogc:NumericDoubleTextBox Grid.Row="0" Grid.Column="2"
                           SelectedValue="{Binding MinimumXValue}" />
        <Label Grid.Row="2" Grid.Column="0"
               Content="Maximal x-value:"/>
        <axogc:NumericDoubleTextBox Grid.Row="2" Grid.Column="2"
                           SelectedValue="{Binding MaximumXValue}" />
        <CheckBox Grid.Row="4"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  IsChecked="{Binding BasedOnMinimumYValue}" 
                  Visibility="{Binding IsBasedOnMinimumYValueEnabled, Converter={x:Static axogcc:FalseToVisibilityCollapsedConverter.Instance}}"
                  Content="Base is on minimum y-value"
                  ToolTip="If checked, the spectrum will be offset with the minimum y-value within the range, and then divided by the area. If false, the spectrum will only be divided by the area."
                  />
    </Grid>
</UserControl>
