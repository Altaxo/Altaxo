<Project Sdk="Microsoft.NET.Sdk" InitialTargets="GenAssInfo">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <LangVersion>preview</LangVersion>
    <nullable>enable</nullable>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>Altaxo</RootNamespace>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <OutputPath>..\..\rtNet\bin</OutputPath>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <NoWarn>CA1416</NoWarn>
    <CoreCompileDependsOn>GenAssInfo</CoreCompileDependsOn>
  </PropertyGroup>

  <!-- Enable StyleCop Analyzers for detecting more XML documentation issues 
  <ItemGroup Condition="'$(StyleCopEnabled)' == 'true'">
    <PackageReference Include="StyleCop.Analyzers" Version="*-*">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Analyzer\NullComparisonAnalyzer\NullComparisonAnalyzer.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
  </ItemGroup>
  -->

  <!-- Enforce XML documentation and treat specific warnings as errors    -->
  <PropertyGroup>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <WarningsAsErrors>CS1570;CS1571;CS1572;CS1573;CS1574;CS1580;CS1581;CS1584;CS1587;CS1589;CS1590;CS1591;CS1592;CS1598;CS1599;CS1710;CS1711;CS1725</WarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Properties\AssemblyInfo.cs" Visible="true" />
  </ItemGroup>
  <ItemGroup>
    <!-- Shared projects (Projects already loaded by Altaxo's main program -->
    <ProjectReference Include="..\Core\AltaxoCore.csproj" />
    <ProjectReference Include="..\Base\AltaxoBase.csproj" />
    <ProjectReference Include="..\Base.Presentation\AltaxoBase.Presentation.csproj" />
    <!-- Projects solely for this plugin -->
    <ProjectReference Include="..\Dom\AltaxoDom.csproj" />
    <ProjectReference Include="..\CodeEditing\AltaxoCodeEditing.csproj" />
    <ProjectReference Include="..\..\Libraries\xaml-math\src\WpfMath\WpfMath.csproj" />
    <ProjectReference Include="..\..\Libraries\Markdig.Wpf\Markdig.Wpf.csproj" />
    <ProjectReference Include="..\MarkdownEditing\AltaxoMarkdownEditing.csproj" />
    <ProjectReference Include="..\HelpViewer\AltaxoHelpViewer.csproj" />
  </ItemGroup>
  
  <UsingTask TaskName="GitVersionFile" AssemblyFile="..\..\MSBuildVersioning.dll" />
  <Target Name="GenAssInfo">
    <GitVersionFile TemplateFile="Properties\AssemblyInfo.cs" DestinationFile="Properties\AssemblyInfo.autogenerated.cs" SettingsFile="..\..\MSBuildVersioning.xml" />
  </Target>
  <Target Name="PreBuild" BeforeTargets="PreBuildEvent">
    <Exec Command="if not exist $(SolutionDir)rtNet\AddIns mkdir $(SolutionDir)rtNet\AddIns&#xD;&#xA;copy $(ProjectDir)AltaxoCore.addin $(SolutionDir)rtNet\AddIns" />
  </Target>
</Project>
